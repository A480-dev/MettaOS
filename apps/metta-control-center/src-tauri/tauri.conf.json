{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "METTA Control Center",
  "version": "2.0.0",
  "identifier": "dev.mettaos.metta-control-center",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "METTA Control Center",
        "width": 960,
        "height": 640,
        "resizable": true
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"]
  }
}
