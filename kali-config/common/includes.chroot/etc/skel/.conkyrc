conky.config = {
    alignment = 'top_right',
    gap_x = 30,
    gap_y = 30,
    background = false,
    own_window = true,
    own_window_type = 'desktop',
    own_window_transparent = true,
    own_window_argb_visual = true,
    own_window_argb_value = 0,
    double_buffer = true,
    update_interval = 1,
    use_xft = true,
    font = 'JetBrains Mono:size=36',
    draw_shades = false,
    default_color = '2BE383',
};

conky.text = [[
${font JetBrains Mono:size=42}${color 2BE383}${time %H:%M:%S}
${font JetBrains Mono:size=13}${color 8FA89A}${time %A, %d %B %Y}
${font JetBrains Mono:size=11}${color 4D5A54}─────────────────────
${font JetBrains Mono:size=11}${color 8FA89A}CPU  ${color 2BE383}${cpu}%  ${color 8FA89A}RAM  ${color 2BE383}${memperc}%
${font JetBrains Mono:size=11}${color 8FA89A}↑ ${color 3FD8E8}${upspeed eth0}  ${color 8FA89A}↓ ${color 3FD8E8}${downspeed eth0}
]];
